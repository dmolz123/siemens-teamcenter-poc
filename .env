# ─────────────────────────────────────────────
# Bluebeam Developer Portal credentials
# Get these from: https://developers.bluebeam.com
# ─────────────────────────────────────────────
BB_CLIENT_ID=
BB_CLIENT_SECRET=

# Optional: pre-seed a refresh token if you have one
# (tokenManager will obtain one automatically on first run)
BB_REFRESH_TOKEN=

# ─────────────────────────────────────────────
# Webhook callback URL
# Use ngrok for local dev: ngrok http 3000
# Then set this to your ngrok URL + /webhook/studio-events
# ─────────────────────────────────────────────
WEBHOOK_CALLBACK_URL=

# ─────────────────────────────────────────────
# PoC demo settings
# ─────────────────────────────────────────────

# Email address to invite as reviewer in the PoC demo
# Must be a real email — Bluebeam will send an invitation
DEMO_REVIEWER_EMAIL=
